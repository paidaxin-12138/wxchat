.home-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.ball-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 24rpx;
}

.money-ball {
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #FFD54F 0%, #66BB6A 45%, #2E7D32 100%);
  box-shadow:
    0 16rpx 48rpx rgba(46, 125, 50, 0.35),
    inset 0 -8rpx 24rpx rgba(0, 0, 0, 0.08),
    inset 0 8rpx 24rpx rgba(255, 255, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: ball-pulse 3s ease-in-out infinite;
}

@keyframes ball-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02); }
}

.ball-amount {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.ball-hint {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #689F38;
}

.poster-btn {
  margin-top: 20rpx;
  font-size: 26rpx;
  background: #fff;
  color: #2E7D32;
  border-radius: 40rpx;
  padding: 12rpx 32rpx;
  border: 2rpx solid #C8E6C9;
  line-height: 1.4;
}
.poster-btn::after { border: none; }

.weekly-btn {
  display: block;
  margin: 8rpx auto 32rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, #66BB6A, #2E7D32);
  color: #FFFFFF;
  border-radius: 48rpx;
  padding: 20rpx 64rpx;
  border: none;
  font-weight: 600;
  line-height: 1.4;
  box-shadow: 0 8rpx 20rpx rgba(46, 125, 50, 0.25);
}
.weekly-btn::after { border: none; }

.action-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx 24rpx;
}

.action-btn {
  width: calc(50% - 16rpx);
  margin: 8rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.12);
}

.action-btn:active {
  transform: scale(0.96);
}

.action-icon {
  display: block;
  margin-bottom: 8rpx;
  line-height: 1;
}

.action-label {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #2E7D32;
  font-weight: 500;
}

.tip-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1B5E20;
  margin-bottom: 12rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.tip-footer {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #9E9E9E;
  padding: 8rpx 32rpx 24rpx;
}

.cup-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.cup-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: #F5F7F0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #555;
  border: 2rpx solid transparent;
}

.cup-active {
  background: #E8F5E9;
  color: #2E7D32;
  border-color: #66BB6A;
  font-weight: 600;
}

.preview-row {
  text-align: center;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #666;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 375px;
  height: 600px;
}

.weekly-report-canvas {
  position: fixed;
  left: -1000px;
  top: -1000px;
  width: 750px;
  height: 1200px;
}
