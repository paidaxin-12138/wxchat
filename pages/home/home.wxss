.home-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.ball-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 48rpx;
}

.money-ball {
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #FFD54F 0%, #66BB6A 45%, #2E7D32 100%);
  box-shadow:
    0 16rpx 48rpx rgba(46, 125, 50, 0.35),
    inset 0 -8rpx 24rpx rgba(0, 0, 0, 0.08),
    inset 0 8rpx 24rpx rgba(255, 255, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: ball-pulse 3s ease-in-out infinite;
}

@keyframes ball-pulse {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.02);
  }
}

.ball-amount {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.ball-hint {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #689F38;
}

.action-row {
  display: flex;
  justify-content: space-around;
  padding: 0 32rpx 32rpx;
}

.action-btn {
  flex: 1;
  margin: 0 12rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.12);
}

.action-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(46, 125, 50, 0.15);
}

.action-emoji {
  font-size: 56rpx;
  line-height: 1.2;
}

.action-label {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #2E7D32;
  font-weight: 500;
}

.tip-card {
  margin-top: 16rpx;
}

.tip-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1B5E20;
  margin-bottom: 12rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.tip-footer {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #9E9E9E;
  padding: 8rpx 32rpx 24rpx;
  line-height: 1.5;
}

.cup-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.cup-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: #F5F7F0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #555555;
  border: 2rpx solid transparent;
}

.cup-active {
  background: #E8F5E9;
  color: #2E7D32;
  border-color: #66BB6A;
  font-weight: 600;
}

.preview-row {
  text-align: center;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #666666;
}
