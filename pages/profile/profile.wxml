<view class="profile-page">
  <view class="user-card card">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
    </button>
    <input class="nickname-input" type="nickname" placeholder="点击设置昵称" value="{{nickName}}" bindinput="onNicknameInput" bindblur="onNicknameBlur" />
    <text class="salary-hint">时薪约 ¥{{hourlyStr}} · 每分钟 ¥{{perMinStr}}</text>
  </view>

  <view class="section-title">收益参数设置</view>
  <view class="settings-card card">
    <view class="setting-item" wx:for="{{settingKeys}}" wx:key="key" data-key="{{item.key}}" data-label="{{item.label}}" bindtap="openEdit">
      <text class="setting-label">{{item.label}}</text>
      <view class="setting-right">
        <text class="setting-value">{{config[item.key]}}</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section-title">数据管理</view>
  <view class="settings-card card">
    <view class="setting-item danger-item" bindtap="clearRecords">
      <text class="setting-label danger-text">清空所有摸鱼记录</text>
    </view>
    <view class="setting-item" bindtap="exportData">
      <text class="setting-label">导出数据（JSON）</text>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <view class="about-card card">
    <text class="about-title">关于 · 摸鱼经济学 v{{version}}</text>
    <text class="about-text">带薪拉屎、喝水、充电——把上班碎片时间量化成「真实收益」。时薪来自你的月薪；喝水按桶装水价；充电按公司电费帮你省下的钱。理性摸鱼，快乐打工。</text>
  </view>
</view>

<view class="modal-mask" wx:if="{{editingKey}}" bindtap="closeEdit">
  <view class="modal-panel" catchtap="preventClose">
    <view class="modal-title">编辑 {{editingLabel}}</view>
    <input class="form-input" type="digit" focus="{{true}}" value="{{editValue}}" bindinput="onEditInput" />
    <button class="btn-primary" bindtap="confirmEdit">保存</button>
    <button class="btn-ghost" style="margin-top:16rpx" bindtap="closeEdit">取消</button>
  </view>
</view>
