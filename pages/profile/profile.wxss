.profile-page {
  padding-bottom: 48rpx;
}

.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
  margin-top: 16rpx;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
}
.avatar-btn::after { border: none; }

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #E8F5E9;
  border: 4rpx solid #C8E6C9;
}

.nickname-input {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #1B5E20;
  text-align: center;
}

.login-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.login-status {
  font-size: 24rpx;
  color: #9E9E9E;
}

.login-status.login-on {
  color: #2E7D32;
  font-weight: 500;
}

.avatar-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9E9E9E;
}

.profile-btn {
  margin-top: 0;
  font-size: 24rpx;
  background: #F1F8E9;
  color: #2E7D32;
  border-radius: 32rpx;
  padding: 8rpx 24rpx;
  border: 1rpx solid #C8E6C9;
  line-height: 1.6;
}

.profile-btn-ghost {
  background: transparent;
  color: #9E9E9E;
  border: 1rpx solid #E0E0E0;
}

.profile-btn::after { border: none; }

.salary-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #689F38;
}

.rank-card { margin-top: 8rpx; }

.rank-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rank-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1B5E20;
}

.rank-arrow {
  font-size: 24rpx;
  color: #689F38;
}

.progress-bar {
  height: 16rpx;
  background: #E8F5E9;
  border-radius: 8rpx;
  margin: 20rpx 0 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #66BB6A, #2E7D32);
  border-radius: 8rpx;
}

.progress-hint {
  font-size: 24rpx;
  color: #999;
}

.honor-card {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.honor-text {
  flex: 1;
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

.honor-text.honor-active {
  color: #C62828;
  font-weight: 600;
}

.honor-arrow {
  font-size: 24rpx;
  color: #689F38;
  white-space: nowrap;
}

.section-title {
  padding: 20rpx 32rpx 8rpx;
  font-size: 26rpx;
  color: #999;
}

.settings-card {
  margin-top: 8rpx;
  padding: 0 32rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child { border-bottom: none; }

.setting-label { font-size: 28rpx; color: #333; }

.setting-right {
  display: flex;
  align-items: center;
}

.setting-value {
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: 500;
  margin-right: 8rpx;
}

.setting-arrow { font-size: 32rpx; color: #ccc; }

.danger-item { justify-content: center; }
.danger-text { color: #C62828; }

.company-item { justify-content: center; }
.company-item-hover { opacity: 0.75; }
.company-text {
  color: #5D4037;
  font-size: 28rpx;
}

.clear-modal-panel {
  width: 620rpx;
  margin: auto;
  align-self: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  box-sizing: border-box;
}

.clear-modal-title {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #1B5E20;
  margin-bottom: 24rpx;
}

.clear-modal-content {
  display: block;
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  text-align: center;
  margin-bottom: 40rpx;
}

.clear-modal-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.clear-btn-confirm {
  background: #C62828;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  line-height: 1.4;
  padding: 20rpx 0;
}
.clear-btn-confirm::after { border: none; }

.clear-btn-cancel {
  background: #E8F5E9;
  color: #2E7D32;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid #C8E6C9;
  line-height: 1.4;
  padding: 20rpx 0;
}
.clear-btn-cancel::after { border: none; }

.about-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1B5E20;
  margin-bottom: 12rpx;
}

.about-text {
  display: block;
  width: 100%;
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  word-break: break-all;
}

.profile-footer {
  margin-top: 8rpx;
  padding-bottom: 24rpx;
}

.footer-slogan {
  display: block;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #C62828;
  margin-bottom: 28rpx;
}

.footer-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.footer-qrcode {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #BDC3C7;
}

.footer-stamp {
  width: 108rpx;
  height: 108rpx;
  border: 4rpx solid #C62828;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #C62828;
  font-weight: 700;
  font-size: 22rpx;
  transform: rotate(-12deg);
  background: rgba(198, 40, 40, 0.06);
  box-shadow: inset 0 0 0 6rpx rgba(198, 40, 40, 0.12);
  line-height: 1.3;
}
