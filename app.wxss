@import './styles/iconfont.wxss';

page {
  background-color: #F5F7F0;
  color: #333333;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
  box-sizing: border-box;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(46, 125, 50, 0.08);
  margin: 24rpx;
  padding: 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #66BB6A 0%, #2E7D32 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(46, 125, 50, 0.25);
}

.btn-primary::after { border: none; }

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-ghost {
  background: #F1F8E9;
  color: #2E7D32;
  border-radius: 48rpx;
  font-size: 28rpx;
  border: 2rpx solid #C8E6C9;
}

.btn-ghost::after { border: none; }

.money-green { color: #2E7D32; font-weight: 600; }
.money-gold { color: #2E7D32; font-weight: 600; }

.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-center {
  align-items: center;
}

.modal-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
  color: #1B5E20;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.modal-title-icon {
  flex-shrink: 0;
}

.form-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.form-input {
  background: #F5F7F0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
}

.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.month-nav-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 36rpx;
  color: #2E7D32;
  background: #E8F5E9;
  border-radius: 50%;
}

.month-nav-label {
  margin: 0 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1B5E20;
  min-width: 200rpx;
  text-align: center;
}

.empty-tip {
  text-align: center;
  color: #999999;
  padding: 80rpx 0;
  font-size: 28rpx;
}
